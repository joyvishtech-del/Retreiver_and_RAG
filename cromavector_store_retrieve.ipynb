from langchain_chroma import Chroma
from langchain_huggingface import HuggingFaceEmbeddings

# Step 1 — Load embedding model
embedding = HuggingFaceEmbeddings(
    model_name="sentence-transformers/all-MiniLM-L6-v2"
)

# Step 2 — create a test dataset and embed it
test1 = [
    "Python is a versatile programming language.",
    "This course is for beginners.",
    "This will teach you all about GENAI."

]

embedded_new = HuggingFaceEmbeddings(
    model_name="sentence-transformers/all-MiniLM-L6-v2"
)

# Step 3 — Load existing Chroma database
vectorstore5 = Chroma.from_texts(
    texts=test1,
    embedding=embedded_new,
    persist_directory="myfifth_chroma_vectorstore"
)

# Step 3 — Inspect what is stored in DB
collection = vectorstore5._collection
data = collection.get()

print("------ DOCUMENTS STORED IN VECTOR DB ------\n")

for i in range(len(data["documents"])):
    print(f"ID: {data['ids'][i]}")
    print(f"Document: {data['documents'][i]}")
    print("-----------------------------------")

print("\nTotal stored documents:", len(data["documents"]))


# Step 4 — Run a query
query = "programming language"

print("\n------ QUERY RESULTS ------\n")

retriever = vectorstore5.as_retriever(search_kwargs={"k":3})

docs = retriever.invoke(query)

for i, doc in enumerate(docs):
    print(f"Result {i+1}:")
    print(doc.page_content)
    print("---------------------------")
